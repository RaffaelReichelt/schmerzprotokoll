# Gemeinsamer API-Key für Frontend (nginx) und Backend liegt NICHT hier,
# sondern im externen Swarm-Secret "nginx_apikey":
#   openssl rand -hex 32 | docker secret create nginx_apikey -

# Das OAuth Client Secret selbst liegt NICHT hier, sondern im externen
# Swarm-Secret "ts_authkey" (docker secret create ts_authkey -).
# Erstellen unter https://login.tailscale.com/admin/settings/oauth,
# dabei den Tag "tag:schmerzprotokoll" vergeben (siehe tailscale/acl-policy.json;
# muss vorher in den Access Controls als tagOwner definiert sein) — OAuth-Clients
# können nur getaggte Geräte anlegen, der gleiche Tag muss unten wieder auftauchen.
TS_EXTRA_ARGS=--advertise-tags=tag:schmerzprotokoll
